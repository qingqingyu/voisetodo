    "NSCalendarsWriteOnlyAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Write Only Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceTodo needs access to add your todos to the system calendar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceTodo 需要日历写入权限，以便把确认后的待办同步到系统日历"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceTodo needs microphone access to record your voice."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceTodo 需要麦克风来录制你的语音"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceTodo needs speech recognition access to understand your voice commands."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceTodo 需要语音识别权限来理解你的语音指令"
