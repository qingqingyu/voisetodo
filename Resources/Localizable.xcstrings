    },
    "settings.personalization.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Learns common words from confirmed todos on this device to improve speech recognition and organization. A few keywords may be sent when processing todos; full history is not sent."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据你确认过的待办，在本机学习常用词，提高语音识别和整理准确度。处理待办时可能发送少量关键词，不发送完整历史记录。"
          }
        }
      }
    },
    "siri.query.empty": {
