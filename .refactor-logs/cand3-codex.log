-            (["周五", "星期五", "礼拜五", "每周五", "每星期五"], 6),
-            (["周六", "星期六", "礼拜六", "每周六", "每星期六"], 7)
-        ]
-
-        var values: [Int] = chineseWeekdays.compactMap { entry in
-            entry.tokens.contains { text.contains($0) } ? entry.value : nil
-        }
-
-        let lower = text.lowercased()
