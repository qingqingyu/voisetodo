diff --git a/Protocols/Domain/RecurrenceDecodingContext.swift b/Protocols/Domain/RecurrenceDecodingContext.swift
new file mode 100644
index 0000000000000000000000000000000000000000..4173abbcce84668031157719888cfc785f25b2f5
--- /dev/null
+++ b/Protocols/Domain/RecurrenceDecodingContext.swift
@@ -0,0 +1,6 @@
+import Foundation
+
+extension CodingUserInfoKey {
+    static let recurrenceReferenceDate = CodingUserInfoKey(rawValue: "VoiceTodo.recurrenceReferenceDate")!
+    static let recurrenceCalendar = CodingUserInfoKey(rawValue: "VoiceTodo.recurrenceCalendar")!
