-        guard let weekStart = calendar.date(byAdding: .day, value: -daysFromMonday + offset * 7, to: today) else {
-            return nil
-        }
-        let mondayBasedOffset = (weekday + 5) % 7
-        return calendar.date(byAdding: .day, value: mondayBasedOffset, to: weekStart)
-    }
-}
