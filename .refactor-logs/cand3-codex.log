-    }
-
-    private static func durationDays(in text: String) -> Int? {
-        let compactText = text.replacingOccurrences(of: " ", with: "")
-        let chinesePatterns = [
-            #"(?:(?:未来|接下来|接下来的|连续|连着|往后|之后的|未来的))([0-9]{1,3}|[一二两三四五六七八九十]{1,3})天"#,
