-            lowercasedText.containsEnglishPhrase("tonight") {
-            return today
-        }
-        if text.contains("后天") ||
-            lowercasedText.containsEnglishPhrase("day after tomorrow") {
-            return calendar.date(byAdding: .day, value: 2, to: today)
