-            }
-            return day
-        }
-
-        return nil
-    }
-}
-
-private extension String {
-    func containsEnglishPhrase(_ phrase: String) -> Bool {
-        let escaped = NSRegularExpression.escapedPattern(for: phrase)
-            .replacingOccurrences(of: "\\ ", with: "\\s+")
-        return range(
-            of: "(?<![A-Za-z])\(escaped)(?![A-Za-z])",
