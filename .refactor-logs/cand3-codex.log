        let filteredResult = try WidgetTodoFetch.recentTodos(
            context: context,
            today: today,
            limit: 10,
            calendar: calendar
        )

        XCTAssertEqual(intermediateResult.map(\.title), ["刚完成规律任务"])
        XCTAssertTrue(try XCTUnwrap(intermediateResult.first).isCompleted)

