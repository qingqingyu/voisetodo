-/// 待办日期解析工具：把 AI 返回的自然语言时间提示转换成自然日
-enum TodoDueDateResolver {
-    static func resolve(
-        dueHint: String?,
-        title: String = "",
-        detail: String = "",
-        referenceDate: Date = Date(),
-        calendar: Calendar = .current
-    ) -> Date? {
-        let text = [dueHint, title, detail]
