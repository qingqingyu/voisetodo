+private struct HomeCalendarState {
+    let selectedDate: Date
+    let visibleMonthAnchor: Date
+    let monthDays: [Date]
+    let weekHeaderDays: [Date]
+    let occurrencesByDay: [String: [TodoOccurrenceData]]
+    let unscheduledTodos: [TodoItemData]
