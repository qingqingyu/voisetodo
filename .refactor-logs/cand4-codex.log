diff --git a/UI/Home/HomeView.swift b/UI/Home/HomeView.swift
index c7340198265252a417b8d51dcc81a4b4234253f4..d4170e07cad4bb94fe55afa84fd5393a1e1384d3
--- a/UI/Home/HomeView.swift
