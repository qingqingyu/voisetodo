+
+            HStack(spacing: WarmSpacing.xs) {
+                ForEach(state.weekHeaderDays, id: \.self) { day in
+                    Text(state.weekdayTitle(for: day))
+                        .font(WarmFont.caption(11))
+                        .foregroundColor(WarmTheme.textSecondary)
+                        .frame(maxWidth: .infinity)
