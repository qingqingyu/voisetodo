   770	extension CalendarOccurrenceStore {
   771	    /// 获取日期区间内的 occurrence，并按日历日分组供 Home 月历渲染。
   772	    func groupedCalendarOccurrences(
   773	        from startDate: Date,
   774	        to endDate: Date,
   775	        calendar: Calendar = .current
   776	    ) -> [String: [TodoOccurrenceData]] {
   777	        Dictionary(grouping: calendarOccurrences(from: startDate, to: endDate)) { occurrence in
   778	            TodoOccurrenceData.dayKey(for: occurrence.occurrenceDate, calendar: calendar)
   779	        }
   780	    }
