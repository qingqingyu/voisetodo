        let locale = (pending.localeIdentifier.flatMap { $0.isEmpty ? nil : Locale(identifier: $0) }) ?? fallbackLocale
        let ext = extractor
        group.addTask {
            await Self.processSinglePending(
                index: index,
                id: pendingId,

