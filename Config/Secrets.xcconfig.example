//
// Secrets.xcconfig.example
//
// 复制为 Secrets.xcconfig 并填入真实值。Secrets.xcconfig 已 gitignore，不会进 commit。
// xcconfig 语法：// 后是注释，所以 URL 里的 // 必须用 $() 隔断，写成 https:/$()/...
//

// AIProxy Worker URL（部署后从 `wrangler deploy` 输出复制，含完整 /v1/todo-extractions 路径）
VOICETODO_AI_PROXY_ENDPOINT = https:/$()/voicetodo-ai-proxy.twjtt.workers.dev/v1/todo-extractions

// APP_TOKEN（与 Cloudflare Worker secret 一致；本地生成命令：openssl rand -hex 24）
VOICETODO_AI_PROXY_APP_TOKEN = replace-with-48-char-hex
